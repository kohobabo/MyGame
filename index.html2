<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>10x10 오목 (Human vs AI)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #f3f4f6; /* Tailwind gray-100 */
        }
        
        #board-container {
            position: relative;
            background-color: #deb887; /* Wood color */
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            /* Make it responsive */
            width: 100%;
            max-width: 500px;
            aspect-ratio: 1 / 1;
            margin: 0 auto;
        }

        #board {
            display: grid;
            grid-template-columns: repeat(10, 1fr);
            grid-template-rows: repeat(10, 1fr);
            width: 100%;
            height: 100%;
            position: relative;
            z-index: 10;
        }

        .cell {
            position: relative;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Lines for the board */
        .cell::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background-color: #333;
            z-index: 1;
        }

        .cell::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            width: 1px;
            background-color: #333;
            z-index: 1;
        }

        /* Edge cell line adjustments to not stick out */
        .cell[data-row="0"]::after { top: 50%; }
        .cell[data-row="9"]::after { bottom: 50%; }
        .cell[data-col="0"]::before { left: 50%; }
        .cell[data-col="9"]::before { right: 50%; }

        /* Preview stone (dotted) for hover */
        .preview-stone {
            position: absolute;
            width: 80%;
            height: 80%;
            border-radius: 50%;
            border: 2px dashed rgba(0, 0, 0, 0.6);
            background-color: rgba(0, 0, 0, 0.1);
            opacity: 0;
            z-index: 15;
            pointer-events: none;
            transition: opacity 0.1s;
        }

        /* Show preview only when it's player's turn and cell is not occupied */
        #board.player-turn .cell:not(.occupied):hover .preview-stone {
            opacity: 1;
        }

        /* The stones */
        .stone {
            width: 80%;
            height: 80%;
            border-radius: 50%;
            z-index: 20;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.4);
            transition: all 0.2s ease-in-out;
            transform: scale(0); /* For animation */
        }

        .stone.placed {
            transform: scale(1);
        }

        .stone.black {
            background: radial-gradient(circle at 30% 30%, #555, #000);
        }

        .stone.white {
            background: radial-gradient(circle at 30% 30%, #fff, #ccc);
            /* White stone needs a tiny border to stand out sometimes */
            border: 1px solid #ddd;
        }
        
        .stone.recent {
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.5); /* Highlight last move */
        }

        /* Overlay for end game */
        #game-over-overlay {
            position: absolute;
            inset: 0;
            background-color: rgba(255,255,255,0.8);
            z-index: 30;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-radius: 8px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        #game-over-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-gray-800 text-white p-4 shadow-md text-center">
        <h1 class="text-3xl font-bold tracking-wider">10x10 오목</h1>
        <p class="text-sm text-gray-300 mt-1">플레이어 (흑) vs 인공지능 (백)</p>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center p-4">
        
        <!-- Status and Controls -->
        <div class="w-full max-w-lg flex justify-between items-center mb-6 bg-white p-4 rounded-lg shadow-sm border border-gray-200">
            <div class="flex items-center space-x-3">
                <div id="turn-indicator" class="w-6 h-6 rounded-full bg-black shadow-md transition-colors duration-300"></div>
                <span id="status-text" class="font-semibold text-lg text-gray-800">플레이어(흑) 차례</span>
            </div>
            <button id="reset-btn" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded hover:bg-indigo-700 transition shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-opacity-50">
                새 게임
            </button>
        </div>

        <!-- Game Board -->
        <div id="board-container">
            <div id="board"></div>
            
            <!-- Game Over Overlay -->
            <div id="game-over-overlay">
                <h2 id="winner-text" class="text-3xl font-bold mb-4 text-gray-800">승리!</h2>
                <button id="overlay-reset-btn" class="px-6 py-2 bg-indigo-600 text-white font-bold rounded-full hover:bg-indigo-700 transition shadow-lg text-lg">
                    다시 하기
                </button>
            </div>
        </div>
        
        <!-- Instructions -->
        <div class="mt-8 text-center text-gray-500 max-w-md">
            <p>5개의 돌을 가로, 세로, 또는 대각선으로 먼저 연결하면 승리합니다.</p>
        </div>

    </main>

    <script>
        const BOARD_SIZE = 10;
        const PLAYER = 1; // Black
        const AI = 2;     // White
        const EMPTY = 0;
        const WIN_CONDITION = 5;

        let board = [];
        let currentPlayer = PLAYER;
        let gameActive = true;
        let lastMove = null;

        const boardElement = document.getElementById('board');
        const statusText = document.getElementById('status-text');
        const turnIndicator = document.getElementById('turn-indicator');
        const gameOverOverlay = document.getElementById('game-over-overlay');
        const winnerText = document.getElementById('winner-text');
        
        // Buttons
        document.getElementById('reset-btn').addEventListener('click', initGame);
        document.getElementById('overlay-reset-btn').addEventListener('click', initGame);

        function initGame() {
            // Reset state
            board = Array.from({ length: BOARD_SIZE }, () => Array(BOARD_SIZE).fill(EMPTY));
            currentPlayer = PLAYER;
            gameActive = true;
            lastMove = null;

            // Reset UI
            boardElement.innerHTML = '';
            boardElement.classList.add('player-turn'); // 플레이어 턴 활성화 (미리보기 표시용)
            gameOverOverlay.classList.remove('show');
            updateStatusText("플레이어(흑) 차례");
            turnIndicator.className = "w-6 h-6 rounded-full shadow-md transition-colors duration-300 bg-black";

            // Create grid cells
            for (let r = 0; r < BOARD_SIZE; r++) {
                for (let c = 0; c < BOARD_SIZE; c++) {
                    const cell = document.createElement('div');
                    cell.className = 'cell';
                    cell.dataset.row = r;
                    cell.dataset.col = c;
                    
                    // Add preview stone element
                    const preview = document.createElement('div');
                    preview.className = 'preview-stone';
                    cell.appendChild(preview);

                    cell.addEventListener('click', () => handleCellClick(r, c));
                    boardElement.appendChild(cell);
                }
            }
        }

        function handleCellClick(row, col) {
            if (!gameActive || currentPlayer !== PLAYER || board[row][col] !== EMPTY) return;

            placeStone(row, col, PLAYER);
            
            if (checkWin(row, col, PLAYER)) {
                endGame(PLAYER);
                return;
            }
            if (checkDraw()) {
                endGame(EMPTY);
                return;
            }

            currentPlayer = AI;
            boardElement.classList.remove('player-turn'); // AI 턴에는 미리보기 숨김
            updateStatusText("AI(백) 생각 중...");
            turnIndicator.className = "w-6 h-6 rounded-full shadow-md transition-colors duration-300 bg-white border border-gray-300";
            
            // Small delay for AI to make it feel natural
            setTimeout(makeAIMove, 300);
        }

        function placeStone(row, col, player) {
            board[row][col] = player;
            lastMove = { row, col, player };

            // Find the cell element
            const index = row * BOARD_SIZE + col;
            const cell = boardElement.children[index];
            cell.classList.add('occupied');

            // Create stone element
            const stone = document.createElement('div');
            stone.className = `stone ${player === PLAYER ? 'black' : 'white'}`;
            
            // Remove 'recent' highlight from all other stones
            document.querySelectorAll('.stone').forEach(s => s.classList.remove('recent'));
            stone.classList.add('recent');

            cell.appendChild(stone);

            // Trigger reflow for animation
            void stone.offsetWidth;
            stone.classList.add('placed');
        }

        function makeAIMove() {
            if (!gameActive) return;

            const bestMove = calculateBestMove();
            placeStone(bestMove.r, bestMove.c, AI);

            if (checkWin(bestMove.r, bestMove.c, AI)) {
                endGame(AI);
                return;
            }
            if (checkDraw()) {
                endGame(EMPTY);
                return;
            }

            currentPlayer = PLAYER;
            boardElement.classList.add('player-turn'); // 플레이어 턴 미리보기 활성화
            updateStatusText("플레이어(흑) 차례");
            turnIndicator.className = "w-6 h-6 rounded-full shadow-md transition-colors duration-300 bg-black";
        }

        // Basic AI: Evaluate all empty cells based on threats and opportunities
        function calculateBestMove() {
            let maxScore = -Infinity;
            let bestMoves = [];

            // If board is empty, play roughly in middle
            let emptyCount = 0;
            for(let r=0; r<BOARD_SIZE; r++) for(let c=0; c<BOARD_SIZE; c++) if(board[r][c]===EMPTY) emptyCount++;
            if(emptyCount === BOARD_SIZE*BOARD_SIZE) return {r: Math.floor(BOARD_SIZE/2), c: Math.floor(BOARD_SIZE/2)};

            for (let r = 0; r < BOARD_SIZE; r++) {
                for (let c = 0; c < BOARD_SIZE; c++) {
                    if (board[r][c] === EMPTY) {
                        // Evaluate score for this cell
                        let score = evaluateCell(r, c);
                        
                        if (score > maxScore) {
                            maxScore = score;
                            bestMoves = [{ r, c }];
                        } else if (score === maxScore) {
                            bestMoves.push({ r, c });
                        }
                    }
                }
            }

            // Pick randomly from best moves to add slight variety
            return bestMoves[Math.floor(Math.random() * bestMoves.length)];
        }

        function evaluateCell(r, c) {
            let score = 0;
            
            // Evaluate for AI (offense)
            score += evaluateDirection(r, c, AI) * 1.1; // Slight preference to win than block
            
            // Evaluate for Player (defense - blocking)
            score += evaluateDirection(r, c, PLAYER);

            // Favor center slightly over edges
            let centerDist = Math.abs(r - BOARD_SIZE/2) + Math.abs(c - BOARD_SIZE/2);
            score -= centerDist * 0.1;

            return score;
        }

        function evaluateDirection(r, c, player) {
            const directions = [
                [0, 1],  // Horizontal
                [1, 0],  // Vertical
                [1, 1],  // Diagonal \
                [1, -1]  // Diagonal /
            ];

            let totalScore = 0;

            for (let [dr, dc] of directions) {
                let count = 1; // Count the stone we are pretending to place
                let openEnds = 0;

                // Check one direction
                let i = 1;
                while (true) {
                    let nr = r + dr * i;
                    let nc = c + dc * i;
                    if (nr < 0 || nr >= BOARD_SIZE || nc < 0 || nc >= BOARD_SIZE) break;
                    if (board[nr][nc] === player) {
                        count++;
                    } else if (board[nr][nc] === EMPTY) {
                        openEnds++;
                        break;
                    } else {
                        break; // Blocked by opponent
                    }
                    i++;
                }

                // Check opposite direction
                i = 1;
                while (true) {
                    let nr = r - dr * i;
                    let nc = c - dc * i;
                    if (nr < 0 || nr >= BOARD_SIZE || nc < 0 || nc >= BOARD_SIZE) break;
                    if (board[nr][nc] === player) {
                        count++;
                    } else if (board[nr][nc] === EMPTY) {
                        openEnds++;
                        break;
                    } else {
                        break; // Blocked by opponent
                    }
                    i++;
                }

                // Score based on count and open ends
                if (count >= 5) totalScore += 100000; // Win
                else if (count === 4 && openEnds === 2) totalScore += 10000; // Guaranteed win next turn
                else if (count === 4 && openEnds === 1) totalScore += 1000;
                else if (count === 3 && openEnds === 2) totalScore += 500;
                else if (count === 3 && openEnds === 1) totalScore += 100;
                else if (count === 2 && openEnds === 2) totalScore += 50;
                else if (count === 2 && openEnds === 1) totalScore += 10;
                else if (count === 1 && openEnds === 2) totalScore += 1;
            }

            return totalScore;
        }

        function checkWin(r, c, player) {
            const directions = [
                [0, 1], [1, 0], [1, 1], [1, -1]
            ];

            for (let [dr, dc] of directions) {
                let count = 1; // Start with the stone just placed

                // Check positive direction
                for (let i = 1; i < WIN_CONDITION; i++) {
                    let nr = r + dr * i;
                    let nc = c + dc * i;
                    if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE && board[nr][nc] === player) {
                        count++;
                    } else {
                        break;
                    }
                }

                // Check negative direction
                for (let i = 1; i < WIN_CONDITION; i++) {
                    let nr = r - dr * i;
                    let nc = c - dc * i;
                    if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE && board[nr][nc] === player) {
                        count++;
                    } else {
                        break;
                    }
                }

                if (count >= WIN_CONDITION) return true;
            }
            return false;
        }

        function checkDraw() {
            for (let r = 0; r < BOARD_SIZE; r++) {
                for (let c = 0; c < BOARD_SIZE; c++) {
                    if (board[r][c] === EMPTY) return false;
                }
            }
            return true;
        }

        function endGame(winner) {
            gameActive = false;
            boardElement.classList.remove('player-turn'); // 게임 종료 시 미리보기 숨김
            
            if (winner === PLAYER) {
                winnerText.textContent = "플레이어 승리!";
                winnerText.className = "text-3xl font-bold mb-4 text-black";
                updateStatusText("플레이어가 승리했습니다!");
            } else if (winner === AI) {
                winnerText.textContent = "인공지능 승리!";
                winnerText.className = "text-3xl font-bold mb-4 text-gray-600";
                updateStatusText("인공지능이 승리했습니다.");
            } else {
                winnerText.textContent = "무승부";
                winnerText.className = "text-3xl font-bold mb-4 text-gray-800";
                updateStatusText("무승부입니다.");
            }

            gameOverOverlay.classList.add('show');
        }

        function updateStatusText(text) {
            statusText.textContent = text;
        }

        // Initialize game when page loads
        window.addEventListener('DOMContentLoaded', initGame);

    </script>
</body>
</html>
